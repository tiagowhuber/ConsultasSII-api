PGHOST=localhost
PGPORT=5432
PGUSER=consultassii_user
PGPASSWORD=your_password
PGDATABASE=consultassii

# Server Configuration
PORT=3000
NODE_ENV=development

# GitHub Actions Scheduler Configuration
SCHEDULER_SECRET=your-super-secret-scheduler-key-here

# SII SimpleAPI API Configuration
API_KEY=your-simpleapi-key-here

# Digital Certificate (.pfx) for SimpleAPI RCV endpoints
# PFX_RUT = personal RUT of the Rep Legal to whom the certificate belongs (NOT the company RUT)
PFX_PATH=/absolute/path/to/certificado.pfx
PFX_PASSWORD=your-pfx-password
PFX_RUT=

# SII Company RUT (used for RutEmpresa in API calls)
SII_RUT=your-company-rut

# Set USE_MOCK=true to use local mock data instead of calling SimpleAPI
USE_MOCK=false

# Digital Certificate for SimpleAPI Impresion/Consulta endpoints
# Set PFX_PATH to the absolute path of the .pfx certificate file when available
PFX_PATH=
PFX_PASSWORD=